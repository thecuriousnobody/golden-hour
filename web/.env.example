# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Speech (Indian-language STT-translate) ---
SARVAM_API_KEY=                        # https://sarvam.ai — saaras:v2.5 STT-translate

# --- Search & places ---
GOOGLE_PLACES_API_KEY=                 # https://console.cloud.google.com — Places API (New)
SERPER_API_KEY=                        # https://serper.dev — free tier: 2,500 searches

# --- Notifications (optional — agent will mock if missing) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox default

# --- Phone normalization ---
DEFAULT_COUNTRY_CODE=1                 # 1 = US, 91 = India (used by sendWhatsApp)

# --- Demo override (route all 4 dispatches to one tester phone) ---
# DEMO_WHATSAPP_OVERRIDE_TO=+13095551234   # Hospital/ambulance/nurse/family all go here

# --- Caller defaults (used if not provided by client) ---
DEFAULT_CALLER_LAT=40.6936             # Peoria, IL center
DEFAULT_CALLER_LNG=-89.5890

# --- Demo caller identity (rendered in the UI; used as the WhatsApp recipient
#     for the "family" channel and as the caller's display name). NEXT_PUBLIC_*
#     so the browser can read them — keep your real numbers out of git. ---
NEXT_PUBLIC_DEMO_CALLER_NAME=Demo Caller
NEXT_PUBLIC_DEMO_CALLER_PHONE=+13095550100
NEXT_PUBLIC_DEMO_FAMILY_NAME=Spouse
NEXT_PUBLIC_DEMO_FAMILY_PHONE=+13095550199
